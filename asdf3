                    str_val = str(value).strip()


                    # Специальные текстовые случаи
                    special_cases = {
                        'исключен': ('Исключен', RGBColor(0, 176, 80)),  # Зеленый
                        'включено': ('Включено', RGBColor(0, 176, 80)),  # Зеленый
